#!/usr/bin/env python3
"""
rtl-auto — RTL 自动 Instance & Connect 工具

用法：
  rtl-auto inst -c <config.toml>      # P1: 增量 instance + wire + params
  rtl-auto full -c <config.toml>      # P2: 全流程生成
  rtl-auto check -c <config.toml>     # CI gate
  rtl-auto config -c <config.toml>    # 显示配置
"""
import sys, os, argparse, re

sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))

from src.config import load_config, get_instances_to_update, apply_params
from src.parser import InstanceBlock
from src.expander import expand_auto, needs_expansion
from src.formatter import format_file, verify_format
from src.generator import generate_full


def cmd_inst(args):
    """P1: 增量 instance + wire + params"""
    if args.config:
        cfg = load_config(args.config)
        apply_params(cfg)  # 将 [[params]] 配置写入实例
        top_file = cfg["top"]["output"]
        instances_to_update = get_instances_to_update(cfg)
        all_instances = cfg.get("_instances", [])

        if not instances_to_update:
            print("[INFO] No submodules with update=true, nothing to do")
            return

        print("[INFO] Top file: " + top_file)
        print("[INFO] Instances to update: " + str([i['name'] for i in instances_to_update]))

        _inst_single_file(top_file, instances_to_update, all_instances, args.no_format)

    else:
        _inst_single_file(args.file, None, None, args.no_format)


def cmd_check(args):
    """CI gate: 检查是否需要更新"""
    cfg = load_config(args.config)
    top_file = cfg["top"]["output"]
    instances = get_instances_to_update(cfg)

    if not instances:
        print("[OK] No instances to check")
        return

    # 用 verilog-batch-diff-auto 检查
    if needs_expansion(top_file):
        print("[NEED UPDATE] " + top_file + " needs AUTO expansion")
        sys.exit(1)
    else:
        print("[OK] " + top_file + " is up to date")

    # 检查 Verible 格式化
    if not verify_format(top_file):
        print("[NEED FORMAT] " + top_file + " needs formatting")
        sys.exit(1)

    print("[OK] All checks passed")


def cmd_config(args):
    """显示配置"""
    cfg = load_config(args.config)
    print("Project: " + cfg['project']['name'])
    print("Top module: " + cfg['top']['module'])
    print("Top file: " + cfg['top']['file'])
    print("Output: " + cfg['top']['output'])
    print("Submodules: " + str(len(cfg['submodules'])))
    for sm in cfg['submodules']:
        print("  {} x{} (update={})".format(sm['module'], sm['count'], sm['update']))
    print("Total instances: " + str(len(cfg.get('_instances', []))))
    for inst in cfg.get('_instances', []):
        print("  {} ({})".format(inst['name'], inst['module']))


def _inst_single_file(top_file, instances, all_instances, no_format):
    """
    对单个顶层文件执行增量 instance + wire + params 更新
    """
    if not os.path.isfile(top_file):
        print("[ERROR] File not found: " + top_file)
        sys.exit(1)

    with open(top_file) as f:
        content = f.read()

    parser = InstanceBlock(content)
    original = content

    # ---- Phase 1: 更新 params ----
    if instances:
        for inst in instances:
            if inst.get("params"):
                block = parser.locate(inst["module"], inst["name"])
                if block:
                    p_list = [[k, v] for k, v in inst["params"].items()]
                    content = parser.replace_params(block, p_list)
                    print("[INFO] Updated params: {} -> {}".format(inst['name'], p_list))
                    parser = InstanceBlock(content)

    # ---- Phase 2: 注入 AUTOINST ----
    if instances:
        for inst in instances:
            # 重新 locate（因为 content 可能已被 params 修改）
            block = parser.locate(inst["module"], inst["name"])
            if not block:
                print("[WARN] Instance not found: {} ({})".format(inst['name'], inst['module']))
                continue
            print("[INFO] Updating instance: {} ({})".format(inst['name'], inst['module']))
            content = parser.replace_with_autoinst(block)
            parser = InstanceBlock(content)

    if content == original:
        print("[INFO] No changes made")
        return

    # ---- Phase 3: 注入 AUTOWIRE ----
    parser = InstanceBlock(content)
    content = parser.inject_autowire()

    # ---- Phase 4: emacs 全量展开 ----
    # 提取子模块文件所在目录作为 library-directories
    lib_dirs = {os.path.dirname(os.path.abspath(top_file))}
    if all_instances:
        for inst in all_instances:
            if inst.get("file"):
                lib_dirs.add(os.path.dirname(os.path.abspath(inst["file"])))

    tmp_file = top_file + ".tmp"
    with open(tmp_file, 'w') as f:
        f.write(content)

    print("[INFO] Running verilog-mode expansion (AUTOINST + AUTOWIRE)...")
    expand_auto(tmp_file, library_dirs=list(lib_dirs))

    with open(tmp_file) as f:
        expanded = f.read()

    # ---- Phase 5: 清理标记 + 多空行 ----
    cleaned = InstanceBlock.remove_auto_markers(expanded)
    cleaned = re.sub(r'\n\s*\n\s*\n', '\n\n', cleaned)

    with open(tmp_file, 'w') as f:
        f.write(cleaned)

    # ---- Phase 6: Verible 格式化 ----
    if not no_format:
        if format_file(tmp_file):
            print("[INFO] Verible formatted")
        else:
            print("[WARN] verible-verilog-format not found, skipping")

    # ---- Phase 7: 写回 ----
    os.replace(tmp_file, top_file)
    print("[DONE] Updated: " + top_file)


def cmd_full(args):
    """P2: 全流程生成"""
    cfg = load_config(args.config)
    apply_params(cfg)
    generate_full(cfg)


def main():
    parser = argparse.ArgumentParser(
        description="rtl-auto — RTL Auto Instance & Connect Tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    # inst
    p_inst = sub.add_parser("inst", help="P1: 增量 instance + wire + params")
    p_inst.add_argument("-c", "--config", help="TOML 配置文件路径")
    p_inst.add_argument("-f", "--file", help="直接指定 .v 文件")
    p_inst.add_argument("--no-format", action="store_true", help="跳过 Verible 格式化")

    # full
    p_full = sub.add_parser("full", help="P2: 全流程生成")
    p_full.add_argument("-c", "--config", required=True, help="TOML 配置文件路径")

    # check
    p_check = sub.add_parser("check", help="CI gate: 检查是否需要更新")
    p_check.add_argument("-c", "--config", required=True, help="TOML 配置文件路径")

    # config
    p_config = sub.add_parser("config", help="显示配置信息")
    p_config.add_argument("-c", "--config", required=True, help="TOML 配置文件路径")

    args = parser.parse_args()

    if args.command == "inst":
        if not args.config and not args.file:
            parser.error("需要 -c <config.toml> 或 -f <file.v>")
        cmd_inst(args)
    elif args.command == "full":
        cmd_full(args)
    elif args.command == "check":
        cmd_check(args)
    elif args.command == "config":
        cmd_config(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
